# Copy to .env for local runs (.env is gitignored). In production these are GitHub Actions secrets.
# NEVER commit real values.

# Core
ANTHROPIC_API_KEY=
DRY_RUN=true                 # true = never send/post anything live. Default safe.

# Shopify (Fan Decor Admin API)
SHOPIFY_STORE=fandecor.myshopify.com
SHOPIFY_ADMIN_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0BAD4YQ80M

# ClickUp
CLICKUP_TOKEN=
CLICKUP_LIST_ID=901615395458
CLICKUP_RETURNS_LIST_ID=901615395484

# TikTok Shop Partner API  (app key/secret provided; tokens come after app approval + shop auth)
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_SHOP_CIPHER=

# Gmail (service account JSON, base64-encoded) — impersonates customerservice@ + marketing@
GMAIL_SERVICE_ACCOUNT_JSON=

# Meta (Instagram + Messenger DMs) — after app review
META_PAGE_ACCESS_TOKEN=
META_IG_ID=
META_PAGE_ID=
